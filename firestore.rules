rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'haribenaya32@gmail.com';
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256;
    }
    function isValidDevice(data) {
      return data.keys().hasAll(['name', 'type', 'relayPin', 'priority', 'userId', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type is string && data.type.size() < 50 &&
             data.relayPin is number && data.relayPin >= 0 &&
             data.priority is number && data.priority >= 1 && data.priority <= 3 &&
             data.status is bool &&
             data.createdAt is timestamp &&
             data.userId == request.auth.uid;
    }
    function isValidEnergyUsage(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'consumption']) &&
             data.userId == request.auth.uid &&
             data.consumption is number && data.consumption >= 0;
    }
    function isValidSchedule(data) {
      return data.keys().hasAll(['deviceId', 'deviceName', 'action', 'time', 'days', 'enabled', 'userId']) &&
             data.deviceId is string &&
             data.deviceName is string && data.deviceName.size() < 100 &&
             data.action in ['ON', 'OFF'] &&
             data.time is string && data.time.matches("^([01]?[0-9]|2[0-3]):[0-5][0-9]$") &&
             data.days is list && data.days.size() <= 7 &&
             data.enabled is bool &&
             data.userId == request.auth.uid;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Device Rules
    match /devices/{deviceId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDevice(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidDevice(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    // Energy Usage Rules
    match /energyUsage/{usageId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidEnergyUsage(request.resource.data);
    }

    // Schedule Rules
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidSchedule(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidSchedule(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    // Grid Status (Public Read, Admin Write - for demo, allow read to all auth)
    match /grid/status {
      allow read: if isAuthenticated();
      allow write: if false; // Only system can update (mocked for demo)
    }
  }
}
