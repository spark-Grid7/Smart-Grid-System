{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "ecoMode": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Device": {
      "title": "Device",
      "description": "Smart appliance or device connected to the grid",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["AC", "Heater", "Pump", "Light", "Other"] },
        "relayPin": { "type": "integer", "description": "GPIO pin number on ESP32" },
        "priority": { "type": "integer", "description": "1: High, 2: Medium, 3: Low" },
        "status": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "relayPin", "priority", "userId"]
    },
    "EnergyUsage": {
      "title": "EnergyUsage",
      "description": "Historical energy consumption record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "consumption": { "type": "number" }
      },
      "required": ["userId", "timestamp", "consumption"]
    },
    "GridConfig": {
      "title": "GridConfig",
      "description": "Global grid status and load shedding schedule",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["stable", "critical"] },
        "livePower": { "type": "number" },
        "loadSheddingSchedule": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Automated ON/OFF schedule for a device",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "deviceName": { "type": "string" },
        "action": { "type": "string", "enum": ["ON", "OFF"] },
        "time": { "type": "string", "description": "HH:mm format" },
        "days": { "type": "array", "items": { "type": "string" } },
        "enabled": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deviceId", "deviceName", "action", "time", "days", "enabled", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/devices/{deviceId}": {
      "schema": "Device",
      "description": "Connected smart devices"
    },
    "/energyUsage/{usageId}": {
      "schema": "EnergyUsage",
      "description": "Historical energy data"
    },
    "/grid/status": {
      "schema": "GridConfig",
      "description": "Global grid information"
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Device automation schedules"
    }
  },
  "realtimeDatabase": {
    "/users/{userId}/hardware": {
      "description": "Hardware node for a user's ESP32 device",
      "properties": {
        "status": {
          "description": "Connectivity and heartbeat status",
          "properties": {
            "isOnline": { "type": "boolean" },
            "isLinked": { "type": "boolean" },
            "lastSeen": { "type": "number" },
            "verified_pins": { "type": "object" }
          }
        },
        "sensors": {
          "description": "Real-time sensor readings",
          "properties": {
            "realtime": {
              "properties": {
                "power": { "type": "number" },
                "voltage": { "type": "number" },
                "current": { "type": "number" }
              }
            }
          }
        },
        "settings": {
          "description": "Device-specific settings",
          "properties": {
            "ecoMode": { "type": "boolean" },
            "macAddress": { "type": "string" }
          }
        },
        "appliances": {
          "description": "Relay control and status for connected devices",
          "additionalProperties": {
            "properties": {
              "name": { "type": "string" },
              "pin": { "type": "integer" },
              "priority": { "type": "integer" },
              "status": { "type": "boolean" },
              "command": { "type": "string", "enum": ["ON", "OFF", "NONE"] }
            }
          }
        },
        "schedules": {
          "description": "Automation schedules synced to hardware",
          "additionalProperties": {
            "schema": "Schedule"
          }
        }
      }
    }
  }
}
